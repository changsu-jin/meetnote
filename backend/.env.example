# MeetNote Server 환경변수
# 이 파일을 .env로 복사하고 필요한 값을 채워주세요.

# 로컬 venv 실행 시 필요 (Docker 이미지에는 모델 포함)
# HUGGINGFACE_TOKEN=

# 선택 — 원격 서버 인증용
# API_KEY=

# 이메일 (SMTP) — 기본값은 Gmail. 사내 메일 서버로 전환 시 변경.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASSWORD=앱비밀번호
# SMTP_USE_TLS=true
# 발신자 이메일(From)은 플러그인 설정에서 관리합니다.

# 아래는 기본값이 있어 변경 불필요. 필요 시 주석 해제.
# WHISPER_MODEL=large-v3-turbo
# WHISPER_LANGUAGE=ko
# WHISPER_DEVICE=auto
# WHISPER_COMPUTE_TYPE=int8
# RECORDINGS_PATH=./data/recordings
# SPEAKER_DB_PATH=./data/speakers.json
# ENCRYPTION_ENABLED=false
# AUTO_DELETE_DAYS=0
